{
  "name": "mimo-usage-watcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/electron/main.js",
  "bin": {
    "mimo-usage-watcher": "./dist/index.js",
    "mimo-watcher": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx scripts/dev-electron.ts",
    "dev:tui": "tsx src/index.tsx",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "electron dist/electron/main.js",
    "start:tui": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "commander": "^14.0.3",
    "ink": "^7.0.4",
    "lucide-react": "^0.561.0",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.7",
    "vite": "^7.2.7",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
